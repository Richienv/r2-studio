# R2·STUDIO env. The active Prisma schema is Postgres (Neon) — see prisma/schema.prisma.

# Neon Postgres (Production + Preview). Pooled URL for the app, direct URL for migrations.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host-direct/db?sslmode=require"

# Per-app API key for Hermes/Ren (mutations only). Generate a fresh 32-char string.
R2_STUDIO_API_KEY="generate-random-32char-string"

NEXT_PUBLIC_APP_URL="https://r2-studio.vercel.app"

# ── Local SQLite fallback (optional) ──
# To run locally on SQLite instead of Neon, restore the SQLite datasource block
# from prisma/schema (provider="sqlite") and the JSON-string json-array helpers,
# then set:
# DATABASE_URL="file:./dev.db"
